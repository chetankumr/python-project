print("Welcome to SIP calculator")
monthly_sip= float(input("Enter Monthly Sip amount:"))
years=float(input("Enter investment period(year):"))
expected_return= float(input("Enter expected annual return (%):"))
months= int(years*12)
monthly_rate= expected_return/12/100
future_value= monthly_sip *(((1+monthly_rate)** months -1)/monthly_rate)*(1+monthly_rate)
total_investment = monthly_sip * months
profit = future_value-total_investment
print("\n------- SIP Result-------")
print("Total Investment: INR",round(total_investment))
print("futue value: INR", round(future_value))
print("Estimated Profit: INR", round(profit))


